# App
APP_NAME=MemoSeed
APP_ENV=development

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Backend
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=memoseed
POSTGRES_USER=memoseed
POSTGRES_PASSWORD=memoseed_password
DATABASE_URL=postgresql+psycopg://memoseed:memoseed_password@localhost:5432/memoseed

# Prisma
PRISMA_DATABASE_URL=postgresql://memoseed:memoseed_password@localhost:5432/memoseed

# AI Provider
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=
