# App
APP_NAME=MemoSeed
APP_ENV=development

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Backend
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_SECRET_KEY=replace_with_a_long_random_secret_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=memoseed
POSTGRES_USER=memoseed
POSTGRES_PASSWORD=memoseed_password
DATABASE_URL=postgresql+psycopg://memoseed:memoseed_password@localhost:5432/memoseed

# Prisma
PRISMA_DATABASE_URL=postgresql://memoseed:memoseed_password@localhost:5432/memoseed

# AI Provider
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=
AI_MODEL=ali6parmak/hy-mt1.5:latest

# TTS Provider
TTS_PROVIDER=volcark
VOLCENGINE_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v3/tts/unidirectional
VOLCENGINE_TTS_API_KEY=
VOLCENGINE_TTS_RESOURCE_ID=seed-tts-2.0
VOLCENGINE_TTS_MODEL=seed-tts-2.0-standard
VOLCENGINE_TTS_ENGLISH_VOICE=en_female_dacey_uranus_bigtts
VOLCENGINE_TTS_CHINESE_VOICE=zh_female_xiaohe_uranus_bigtts

# CosyVoice 2.0 Local TTS
COSYVOICE_BASE_URL=http://localhost:50000
COSYVOICE_ENGLISH_SPEAKER=英文女
COSYVOICE_CHINESE_SPEAKER=中文女
